# ── App ────────────────────────────────────────────────────────────────────────
SECRET_KEY=                        # Generate: python -c "import secrets; print(secrets.token_hex(32))"
DEBUG=true
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=["http://localhost:3000", "https://aitdl.com"]
RAILWAY_ENVIRONMENT=development

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5434/aitdl_dev

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=                      # Your Supabase project URL
SUPABASE_ANON_KEY=                 # Your Supabase anon/public key
SUPABASE_JWT_SECRET=               # Your Supabase JWT secret (for decoding tokens)
SUPABASE_SERVICE_ROLE_KEY=         # Your Supabase service_role key (optional, for admin tasks)

# ── AI Providers ───────────────────────────────────────────────────────────────
AI_STUB_MODE=true                  # Set to false to use real API keys
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_HOST=http://localhost:11434

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
