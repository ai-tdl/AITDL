# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: PostgreSQL on port 5434
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5434/aitdl_dev
# Production (Railway): set via dashboard — do not commit
# DATABASE_URL=postgresql+asyncpg://...railway.internal/railway

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5500,http://localhost:7700,https://aitdl.com,https://www.aitdl.com

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
DEBUG=true

# ── Supabase Auth & DB (Phase 4) ──────────────────────────────────────────────
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# JWT algorithm is usually HS256 by default in Supabase (check API Settings)
JWT_ALGORITHM=HS256

# ── WhatsApp Integration (Phase 3) ────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your-meta-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_ADMIN_PHONE=your-admin-phone-with-country-code
WHATSAPP_STUB_MODE=true
