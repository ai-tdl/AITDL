# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: PostgreSQL on port 5434
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5434/aitdl_dev
# Production (Railway): set via dashboard — do not commit
# DATABASE_URL=postgresql+asyncpg://...railway.internal/railway

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5500,http://localhost:7700,https://aitdl.com,https://www.aitdl.com

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
DEBUG=true

# ── Admin Auth (Phase 3) ──────────────────────────────────────────────────────
# Used only by scripts/create_admin.py — never hardcoded in code
ADMIN_EMAIL=iamadmin@aitdl.com
ADMIN_PASSWORD=your-admin-password-here

# JWT — generate a 64-char random string for JWT_SECRET_KEY
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-64-char-random-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── Supabase (Phase 4 — leave blank until Phase 4) ────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

